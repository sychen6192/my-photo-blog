---
// 原生 <dialog> 燈箱。照片資料由相簿頁輸出的 #lightbox-data JSON script 提供。
---
<dialog
  id="lightbox"
  class="m-0 h-dvh max-h-none w-screen max-w-none bg-transparent p-0 text-neutral-100 backdrop:bg-black/85"
>
  <div id="lb-stage" class="flex h-full w-full items-center justify-center p-4 sm:p-10">
    <button id="lb-close" type="button" aria-label="關閉"
      class="absolute right-3 top-3 z-10 grid h-12 w-12 select-none place-items-center rounded-full bg-white/10 text-2xl text-white transition hover:bg-white/20 sm:right-4 sm:top-4">✕</button>
    <button id="lb-prev" type="button" aria-label="上一張"
      class="absolute left-2 top-1/2 z-10 grid h-12 w-12 -translate-y-1/2 select-none place-items-center rounded-full bg-white/10 text-3xl text-white transition hover:bg-white/20 sm:left-6">‹</button>
    <button id="lb-next" type="button" aria-label="下一張"
      class="absolute right-2 top-1/2 z-10 grid h-12 w-12 -translate-y-1/2 select-none place-items-center rounded-full bg-white/10 text-3xl text-white transition hover:bg-white/20 sm:right-6">›</button>
    <div id="lb-loading" class="pointer-events-none absolute inset-0 hidden">
      <div class="grid h-full w-full place-items-center">
        <div class="h-9 w-9 animate-spin rounded-full border-2 border-white/25 border-t-white/90"></div>
      </div>
    </div>
    <figure id="lb-figure" class="m-0 flex max-h-full flex-col items-center">
      <img id="lb-img" alt="" class="max-h-[82vh] max-w-full touch-none select-none rounded object-contain will-change-transform" />
      <figcaption class="mt-3 text-center">
        <p id="lb-title" class="text-sm text-neutral-100"></p>
        <p id="lb-exif" class="mt-1 text-xs tracking-wide text-neutral-400"></p>
      </figcaption>
    </figure>
  </div>
</dialog>

<script>
  import { imgUrl } from '../lib/image';
  import { wrapIndex, clamp, touchDistance, classifySwipe, clampPan } from '../lib/lightbox';

  interface LbPhoto { filename: string; title: string; exif: string; lens: string }

  const dialog = document.getElementById('lightbox') as HTMLDialogElement | null;
  const dataEl = document.getElementById('lightbox-data');
  if (dialog && dataEl) {
    const photos: LbPhoto[] = JSON.parse(dataEl.textContent || '[]');
    const imgEl = document.getElementById('lb-img') as HTMLImageElement;
    const titleEl = document.getElementById('lb-title') as HTMLElement;
    const exifEl = document.getElementById('lb-exif') as HTMLElement;
    const stage = document.getElementById('lb-stage') as HTMLElement;
    const figure = document.getElementById('lb-figure') as HTMLElement;
    const loadingEl = document.getElementById('lb-loading') as HTMLElement;
    let current = 0;

    // 縮放/平移狀態(行動端手勢)
    const MAX_SCALE = 4;
    const DOUBLE_TAP_SCALE = 2.5;
    const SWIPE_THRESHOLD = 50; // px,單指水平超過才算左右切換
    const TAP_MAX_MOVE = 10;    // px,小於此位移視為「點按」而非滑動
    const DOUBLE_TAP_MS = 300;  // 兩次點按間隔小於此值算雙擊
    let scale = 1, tx = 0, ty = 0;
    let startX = 0, startY = 0, startTx = 0, startTy = 0;
    let startDist = 0, startScale = 1, baseW = 0, baseH = 0;
    let moved = false, pinching = false, lastTap = 0;

    const applyTransform = () => {
      imgEl.style.transform = `translate(${tx}px, ${ty}px) scale(${scale})`;
    };
    const resetZoom = () => { scale = 1; tx = 0; ty = 0; imgEl.style.transform = ''; };

    const render = () => {
      const p = photos[current];
      if (!p) return;
      imgEl.style.transition = '';
      resetZoom(); // 換照片時回到未放大狀態
      loadingEl.classList.remove('hidden'); // 換圖時顯示讀取指示,圖載好後隱藏
      imgEl.src = imgUrl(p.filename, 1600);
      imgEl.alt = p.title;
      titleEl.textContent = p.title;
      exifEl.textContent = [p.exif, p.lens].filter(Boolean).join('  ·  ');
    };
    imgEl.addEventListener('load', () => loadingEl.classList.add('hidden'));
    imgEl.addEventListener('error', () => loadingEl.classList.add('hidden'));
    const open = (i: number) => {
      current = wrapIndex(i, photos.length);
      render();
      if (!dialog.open) dialog.showModal();
      document.body.style.overflow = 'hidden';
    };
    const step = (d: number) => { current = wrapIndex(current + d, photos.length); render(); };

    document.querySelectorAll<HTMLElement>('[data-lightbox-index]').forEach((el) => {
      el.addEventListener('click', () => open(Number(el.dataset.lightboxIndex)));
    });
    document.getElementById('lb-close')!.addEventListener('click', () => dialog.close());
    document.getElementById('lb-prev')!.addEventListener('click', (e) => { e.stopPropagation(); step(-1); });
    document.getElementById('lb-next')!.addEventListener('click', (e) => { e.stopPropagation(); step(1); });
    figure.addEventListener('click', (e) => e.stopPropagation());
    stage.addEventListener('click', () => dialog.close());

    // 行動端手勢:單指左右滑切換、雙指 pinch 縮放、放大後單指平移、雙擊放大/還原
    imgEl.addEventListener('touchstart', (e) => {
      imgEl.style.transition = '';
      baseW = imgEl.clientWidth;
      baseH = imgEl.clientHeight;
      if (e.touches.length === 2) {
        pinching = true;
        moved = true;
        startDist = touchDistance(e.touches[0], e.touches[1]);
        startScale = scale;
      } else if (e.touches.length === 1) {
        pinching = false;
        moved = false;
        startX = e.touches[0].clientX;
        startY = e.touches[0].clientY;
        startTx = tx;
        startTy = ty;
      }
    }, { passive: false });

    imgEl.addEventListener('touchmove', (e) => {
      if (e.touches.length >= 2) {
        if (startDist > 0) {
          scale = clamp(startScale * (touchDistance(e.touches[0], e.touches[1]) / startDist), 1, MAX_SCALE);
          ({ tx, ty } = clampPan(tx, ty, scale, baseW, baseH));
          applyTransform();
        }
        moved = true;
        e.preventDefault();
        return;
      }
      const t = e.touches[0];
      const dx = t.clientX - startX;
      const dy = t.clientY - startY;
      if (Math.abs(dx) > TAP_MAX_MOVE || Math.abs(dy) > TAP_MAX_MOVE) moved = true;
      if (scale > 1) {
        ({ tx, ty } = clampPan(startTx + dx, startTy + dy, scale, baseW, baseH));
        applyTransform();
        e.preventDefault();
      } else if (moved) {
        e.preventDefault(); // 攔下水平滑動,放開時再決定是否切換
      }
    }, { passive: false });

    imgEl.addEventListener('touchend', (e) => {
      if (e.touches.length >= 1) {
        // 還有手指(pinch 放開其中一指)→ 以剩下那指重設平移基準
        startX = e.touches[0].clientX;
        startY = e.touches[0].clientY;
        startTx = tx;
        startTy = ty;
        return;
      }
      if (pinching) {
        pinching = false;
        if (scale <= 1.05) { imgEl.style.transition = 'transform .2s ease'; resetZoom(); }
        return;
      }
      if (!moved) {
        const now = Date.now();
        if (now - lastTap < DOUBLE_TAP_MS) { // 雙擊:放大 ↔ 還原
          lastTap = 0;
          imgEl.style.transition = 'transform .2s ease';
          if (scale > 1) resetZoom();
          else { scale = DOUBLE_TAP_SCALE; tx = 0; ty = 0; applyTransform(); }
        } else {
          lastTap = now;
        }
        return;
      }
      if (scale <= 1) { // 未放大時的單指滑動 → 左右切換
        const ct = e.changedTouches[0];
        const dir = ct ? classifySwipe(ct.clientX - startX, ct.clientY - startY, SWIPE_THRESHOLD) : 0;
        if (dir !== 0) step(dir);
      }
    });

    dialog.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft') step(-1);
      else if (e.key === 'ArrowRight') step(1);
    });
    dialog.addEventListener('close', () => { document.body.style.overflow = ''; resetZoom(); });
  }
</script>
