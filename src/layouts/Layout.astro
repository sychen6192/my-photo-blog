---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: string;
  preloadImage?: string;
}

const {
  title = 'cloud.filmz — Fujifilm Street Photography',
  description = 'Fujifilm X-T50 street photography journal — Tokyo, Taipei, and beyond.',
  image,
  type = 'website',
  preloadImage,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = image ? new URL(image, Astro.site).href : undefined;
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content="cloud.filmz" />
    <meta property="og:locale" content="ja_JP" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}
    {preloadImage && <link rel="preload" as="image" href={preloadImage} fetchpriority="high" />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-[#16181c] text-neutral-200 antialiased">
    <slot />
    <footer class="border-t border-neutral-900 px-6 py-10 text-center">
      <p class="text-sm font-medium tracking-wide text-neutral-300">cloud.filmz</p>
      <p class="mt-1 text-[0.7rem] uppercase tracking-widest text-neutral-600">Fujifilm Street Photography</p>
      <p class="mt-4 text-[0.7rem] tracking-wide text-neutral-700">© {year} cloud.filmz</p>
    </footer>

    <!-- 電影感材質:暗角 + 極淡底片顆粒(不擋點擊;lightbox 在更上層不受影響) -->
    <div aria-hidden="true" class="lb-vignette pointer-events-none fixed inset-0 z-[1]"></div>
    <div aria-hidden="true" class="lb-grain pointer-events-none fixed inset-0 z-[1] opacity-[0.04] mix-blend-overlay"></div>

    <script>
      // 圖片載入時淡入(漸進增強:沒有 JS 時照常顯示)。過場由 Tailwind 的 transition class 提供。
      document.querySelectorAll<HTMLImageElement>('img[data-fade]').forEach((img) => {
        if (img.complete) return;
        img.style.opacity = '0';
        const show = () => { img.style.opacity = '1'; };
        img.addEventListener('load', show, { once: true });
        img.addEventListener('error', show, { once: true });
      });
    </script>
  </body>
</html>

<style is:global>
  html {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
  }
  /* 行動端:關掉按鈕/連結的雙擊放大與點擊灰底高亮(保留雙指 pinch 縮放) */
  button,
  a {
    touch-action: manipulation;
    -webkit-tap-highlight-color: transparent;
  }
  /* 電影感:暗角 + 極淡底片顆粒 */
  .lb-vignette {
    background: radial-gradient(ellipse at center, transparent 60%, rgba(0, 0, 0, 0.3) 100%);
  }
  .lb-grain {
    background-image: url("data:image/svg+xml,%3Csvg%20xmlns='http://www.w3.org/2000/svg'%20width='120'%20height='120'%3E%3Cfilter%20id='n'%3E%3CfeTurbulence%20type='fractalNoise'%20baseFrequency='0.9'%20numOctaves='2'%20stitchTiles='stitch'/%3E%3C/filter%3E%3Crect%20width='120'%20height='120'%20filter='url(%23n)'/%3E%3C/svg%3E");
    background-size: 140px 140px;
  }
  /* 尊重「減少動態效果」:關掉圖片淡入過場 */
  @media (prefers-reduced-motion: reduce) {
    img[data-fade] {
      transition: none !important;
    }
  }
</style>
