---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 — cloud.filmz" description="找不到這個頁面。">
  <main class="flex min-h-dvh flex-col items-center justify-center px-6 text-center">
    <p class="text-7xl font-light tracking-tight text-white">404</p>
    <p class="mt-4 text-sm text-neutral-400">這個頁面不存在,或已經被移走了。</p>
    <a
      href="/"
      class="mt-8 inline-block border-b border-neutral-700 pb-0.5 text-xs uppercase tracking-widest text-neutral-300 transition hover:text-white"
    >
      ← 回首頁
    </a>
  </main>
</Layout>
