---
import { sanityClient } from 'sanity:client';
import { PortableText } from '@portabletext/react';
import Layout from '../../layouts/Layout.astro';
import { imgUrl } from '../../lib/image';
import Lightbox from '../../components/Lightbox.astro';

interface Photo {
  filename: string;
  title?: string;
  camera?: string;
  lens?: string;
  exif?: string;
}

interface Album {
  _id: string;
  title: string;
  slug: { current: string };
  description?: any[];
  photos: Photo[];
}

export async function getStaticPaths() {
  const albums: { slug: { current: string } }[] = await sanityClient.fetch(`
    *[_type == "album" && defined(slug.current)]{ slug }
  `);

  return albums.map((album) => ({
    params: { slug: album.slug.current },
  }));
}

const { slug } = Astro.params;

const album: Album = await sanityClient.fetch(
  `*[_type == "album" && slug.current == $slug][0]{
    _id,
    title,
    slug,
    description,
    "photos": coalesce(photos[]{ filename, title, camera, lens, exif }, [])
  }`,
  { slug }
);

if (!album) {
  return Astro.redirect('/404');
}
---

<Layout title={`${album.title} — cloud.filmz`}>
  <main class="min-h-dvh pb-20">
    <header class="border-b border-neutral-800 px-6 py-10">
      <a href="/" class="mb-6 inline-block text-xs uppercase tracking-widest text-neutral-500 transition hover:text-neutral-300">
        ← All Albums
      </a>
      <h1 class="text-2xl font-medium tracking-tight text-white sm:text-3xl">
        {album.title}
      </h1>
      {album.description && album.description.length > 0 && (
        <div class="prose prose-invert mt-4 max-w-2xl text-sm leading-relaxed text-neutral-400">
          <PortableText value={album.description} />
        </div>
      )}
      <p class="mt-4 text-xs tracking-wide text-neutral-600">
        {album.photos.length} {album.photos.length === 1 ? 'photo' : 'photos'}
      </p>
    </header>

    {album.photos.length === 0 ? (
      <div class="flex h-[40vh] items-center justify-center text-sm text-neutral-600">
        <p>This album has no photos yet.</p>
      </div>
    ) : (
      <div class="grid grid-cols-1 gap-3.5 p-3.5 sm:grid-cols-2 lg:grid-cols-3">
        {album.photos.map((photo, i) => (
          <button
            type="button"
            data-lightbox-index={i}
            class="group block w-full cursor-zoom-in overflow-hidden rounded-md bg-neutral-900 text-left"
          >
            <div class="aspect-[3/2] overflow-hidden">
              <img
                src={imgUrl(photo.filename, 800)}
                srcset={`${imgUrl(photo.filename, 400)} 400w, ${imgUrl(photo.filename, 800)} 800w, ${imgUrl(photo.filename, 1200)} 1200w`}
                sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
                alt={photo.title ?? ''}
                loading="lazy"
                decoding="async"
                class="h-full w-full object-cover contrast-[1.05] saturate-[.92] transition duration-500 motion-safe:group-hover:scale-[1.03]"
              />
            </div>
            {(photo.title || photo.exif || photo.lens) && (
              <div class="px-3.5 pb-4 pt-3">
                {photo.title && (
                  <h2 class="truncate text-sm font-normal tracking-tight text-neutral-200">{photo.title}</h2>
                )}
                {photo.exif && (
                  <p class="mt-1 text-[0.72rem] tracking-wide text-neutral-400">{photo.exif}</p>
                )}
                {photo.lens && (
                  <p class="mt-0.5 text-[0.7rem] tracking-wide text-neutral-500">{photo.lens}</p>
                )}
              </div>
            )}
          </button>
        ))}
      </div>
    )}
    {album.photos.length > 0 && (
      <Fragment>
        <script type="application/json" id="lightbox-data" is:inline set:html={JSON.stringify(
          album.photos.map((p) => ({ filename: p.filename, title: p.title ?? '', exif: p.exif ?? '', lens: p.lens ?? '' }))
        ).replace(/<\/script>/gi, '<\\/script>')} />
        <Lightbox />
      </Fragment>
    )}
  </main>
</Layout>
