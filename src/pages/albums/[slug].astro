---
import { sanityClient } from 'sanity:client';
import { PortableText } from '@portabletext/react';
import Layout from '../../layouts/Layout.astro';
import { imgUrl } from '../../lib/image';

interface Post {
  _id: string;
  title: string;
  coverImage: string;
  camera?: string;
  lens?: string;
  exif?: string;
}

interface Album {
  _id: string;
  title: string;
  slug: { current: string };
  description?: any[];
  posts: Post[];
}

export async function getStaticPaths() {
  const albums: { slug: { current: string } }[] = await sanityClient.fetch(`
    *[_type == "album" && defined(slug.current)]{ slug }
  `);

  return albums.map((album) => ({
    params: { slug: album.slug.current },
  }));
}

const { slug } = Astro.params;

const album: Album = await sanityClient.fetch(
  `*[_type == "album" && slug.current == $slug][0]{
    _id,
    title,
    slug,
    description,
    "posts": *[_type == "post" && references(^._id)] | order(_createdAt desc){
      _id,
      title,
      coverImage,
      camera,
      lens,
      exif
    }
  }`,
  { slug }
);

if (!album) {
  return Astro.redirect('/404');
}
---

<Layout title={`${album.title} — cloud.filmz`}>
  <main class="min-h-dvh pb-20">
    <header class="border-b border-neutral-800 px-6 py-10">
      <a href="/" class="mb-6 inline-block text-xs uppercase tracking-widest text-neutral-500 transition hover:text-neutral-300">
        ← All Albums
      </a>
      <h1 class="text-2xl font-medium tracking-tight text-white sm:text-3xl">
        {album.title}
      </h1>
      {album.description && album.description.length > 0 && (
        <div class="prose prose-invert mt-4 max-w-2xl text-sm leading-relaxed text-neutral-400">
          <PortableText value={album.description} />
        </div>
      )}
      <p class="mt-4 text-xs tracking-wide text-neutral-600">
        {album.posts.length} {album.posts.length === 1 ? 'photo' : 'photos'}
      </p>
    </header>

    {album.posts.length === 0 ? (
      <div class="flex h-[40vh] items-center justify-center text-sm text-neutral-600">
        <p>This album has no photos yet.</p>
      </div>
    ) : (
      <div class="grid grid-cols-1 gap-px px-px sm:grid-cols-2 lg:grid-cols-3">
        {album.posts.map((post) => (
          <article class="group relative overflow-hidden bg-neutral-900">
            <div class="aspect-[3/2] overflow-hidden">
              <img
                src={imgUrl(post.coverImage, 800)}
                srcset={`${imgUrl(post.coverImage, 400)} 400w, ${imgUrl(post.coverImage, 800)} 800w, ${imgUrl(post.coverImage, 1200)} 1200w`}
                sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
                alt={post.title}
                loading="lazy"
                decoding="async"
                class="h-full w-full object-cover brightness-90 transition duration-500 group-hover:scale-[1.03] group-hover:brightness-100"
              />
            </div>
            <div class="bg-gradient-to-b from-neutral-900 to-neutral-950 px-4 pb-4 pt-3.5">
              <h2 class="truncate text-sm font-normal text-neutral-200">{post.title}</h2>
              {post.exif && (
                <p class="mt-1 text-[0.72rem] tracking-wide text-neutral-500">{post.exif}</p>
              )}
              {post.lens && (
                <p class="mt-0.5 text-[0.7rem] tracking-wide text-neutral-600">{post.lens}</p>
              )}
            </div>
          </article>
        ))}
      </div>
    )}
  </main>
</Layout>
