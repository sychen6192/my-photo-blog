---
import { sanityClient } from 'sanity:client';
import { PortableText } from '@portabletext/react';
import Layout from '../../layouts/Layout.astro';
import { imgUrl } from '../../lib/image';
import Lightbox from '../../components/Lightbox.astro';

interface Photo {
  filename: string;
  title?: string;
  camera?: string;
  lens?: string;
  exif?: string;
}

interface Album {
  _id: string;
  title: string;
  slug: { current: string };
  description?: any[];
  cover?: string | null;
  photos: Photo[];
}

export async function getStaticPaths() {
  const albums: { slug: { current: string } }[] = await sanityClient.fetch(`
    *[_type == "album" && defined(slug.current)]{ slug }
  `);

  return albums.map((album) => ({
    params: { slug: album.slug.current },
  }));
}

const { slug } = Astro.params;

const album: Album = await sanityClient.fetch(
  `*[_type == "album" && slug.current == $slug][0]{
    _id,
    title,
    slug,
    description,
    "cover": coalesce(coverImage, photos[0].filename),
    "photos": coalesce(photos[]{ filename, title, camera, lens, exif }, [])
  }`,
  { slug }
);

if (!album) {
  return Astro.redirect('/404');
}

// 給 <head> 用的純文字描述與分享圖
const plainDesc = (album.description ?? [])
  .map((b: any) => (b.children ?? []).map((c: any) => c.text).join(''))
  .join(' ')
  .trim();
const metaDescription = (plainDesc || `${album.title} · ${album.photos.length} 張照片`).slice(0, 160);
const ogImage = album.cover ? imgUrl(album.cover, 1200) : undefined;
const lcp = album.photos[0] ? imgUrl(album.photos[0].filename, 800) : undefined;

// 相簿之間的上一個/下一個(依建立時間,與首頁一致)
const navList: { title: string; slug: string }[] = await sanityClient.fetch(
  `*[_type == "album" && defined(slug.current)] | order(_createdAt desc){ title, "slug": slug.current }`
);
const navIdx = navList.findIndex((a) => a.slug === slug);
const prevAlbum = navIdx > 0 ? navList[navIdx - 1] : null;
const nextAlbum = navIdx >= 0 && navIdx < navList.length - 1 ? navList[navIdx + 1] : null;
---

<Layout title={`${album.title} — cloud.filmz`} description={metaDescription} image={ogImage} type="article" preloadImage={lcp}>
  <main class="min-h-dvh pb-20">
    <header class="border-b border-neutral-800 px-6 py-10">
      <a href="/" class="mb-6 inline-block text-xs uppercase tracking-widest text-neutral-500 transition hover:text-neutral-300">
        ← All Albums
      </a>
      <h1 class="text-2xl font-medium tracking-tight text-white sm:text-3xl">
        {album.title}
      </h1>
      {album.description && album.description.length > 0 && (
        <div class="prose prose-invert mt-4 max-w-2xl text-sm leading-relaxed text-neutral-400">
          <PortableText value={album.description} />
        </div>
      )}
      <p class="mt-4 text-xs tracking-wide text-neutral-600">
        {album.photos.length} {album.photos.length === 1 ? 'photo' : 'photos'}
      </p>
    </header>

    {album.photos.length === 0 ? (
      <div class="flex h-[40vh] items-center justify-center text-sm text-neutral-600">
        <p>This album has no photos yet.</p>
      </div>
    ) : (
      <div class="columns-1 gap-3.5 p-3.5 sm:columns-2 lg:columns-3">
        {album.photos.map((photo, i) => (
          <button
            type="button"
            data-lightbox-index={i}
            class="group mb-3.5 block w-full cursor-zoom-in overflow-hidden rounded-md bg-neutral-800 text-left break-inside-avoid"
          >
            <img
              src={imgUrl(photo.filename, 800)}
              srcset={`${imgUrl(photo.filename, 400)} 400w, ${imgUrl(photo.filename, 800)} 800w, ${imgUrl(photo.filename, 1200)} 1200w`}
              sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
              alt={photo.title || `${album.title} — ${i + 1}`}
              loading="lazy"
              decoding="async"
              data-fade
              class="block h-auto w-full contrast-[1.05] saturate-[.92] transition duration-500 motion-safe:group-hover:scale-[1.03]"
            />
            {(photo.title || photo.exif || photo.lens) && (
              <div class="px-3.5 pb-4 pt-3">
                {photo.title && (
                  <h2 class="truncate text-sm font-normal tracking-tight text-neutral-200">{photo.title}</h2>
                )}
                {photo.exif && (
                  <p class="mt-1 text-[0.72rem] tracking-wide text-neutral-400">{photo.exif}</p>
                )}
                {photo.lens && (
                  <p class="mt-0.5 text-[0.7rem] tracking-wide text-neutral-500">{photo.lens}</p>
                )}
              </div>
            )}
          </button>
        ))}
      </div>
    )}
    {(prevAlbum || nextAlbum) && (
      <nav class="mx-auto mt-6 flex max-w-5xl items-stretch justify-between gap-4 border-t border-neutral-900 px-6 pt-8 text-sm">
        {prevAlbum ? (
          <a href={`/albums/${prevAlbum.slug}`} class="max-w-[45%] text-neutral-400 transition hover:text-white">
            <span class="block text-[0.7rem] uppercase tracking-widest text-neutral-600">← 上一個相簿</span>
            <span class="mt-1 block truncate">{prevAlbum.title}</span>
          </a>
        ) : (
          <span />
        )}
        {nextAlbum ? (
          <a href={`/albums/${nextAlbum.slug}`} class="max-w-[45%] text-right text-neutral-400 transition hover:text-white">
            <span class="block text-[0.7rem] uppercase tracking-widest text-neutral-600">下一個相簿 →</span>
            <span class="mt-1 block truncate">{nextAlbum.title}</span>
          </a>
        ) : (
          <span />
        )}
      </nav>
    )}
    {album.photos.length > 0 && (
      <Fragment>
        <script type="application/json" id="lightbox-data" is:inline set:html={JSON.stringify(
          album.photos.map((p, i) => ({ filename: p.filename, title: p.title ?? '', exif: p.exif ?? '', lens: p.lens ?? '', alt: p.title || `${album.title} — ${i + 1}` }))
        ).replace(/<\/script>/gi, '<\\/script>')} />
        <Lightbox />
      </Fragment>
    )}
  </main>
</Layout>
