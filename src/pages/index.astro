---
import { sanityClient } from 'sanity:client';
import Layout from '../layouts/Layout.astro';
import { imgUrl } from '../lib/image';

interface Album {
  _id: string;
  title: string;
  slug: { current: string };
  coverImage: string | null;
  photoCount: number;
}

const albums: Album[] = await sanityClient.fetch(`
  *[_type == "album"] | order(_createdAt desc) {
    _id,
    title,
    slug,
    "coverImage": coalesce(coverImage, photos[0].filename),
    "photoCount": count(photos)
  }
`);

const ogCover = albums.find((a) => a.coverImage)?.coverImage ?? null;
const lcpCover = albums[0]?.coverImage ?? null;
---

<Layout
  image={ogCover ? imgUrl(ogCover, 1200) : undefined}
  preloadImage={lcpCover ? imgUrl(lcpCover, 800) : undefined}
>
  <main class="flex-1 pb-20">
    <header class="flex items-baseline gap-4 border-b border-neutral-800 px-6 py-8 mb-8">
      <span class="text-lg font-medium tracking-wide text-white">cloud.filmz</span>
      <span class="text-xs font-light uppercase tracking-widest text-neutral-600">
        Travel Albums
      </span>
    </header>

    {albums.length === 0 ? (
      <div class="flex h-[60vh] items-center justify-center text-sm text-neutral-600">
        <p>
          No albums yet. Create one in
          <a href="/admin" class="border-b border-neutral-700 text-neutral-400 ml-1">/admin</a>.
        </p>
      </div>
    ) : (
      <div class="grid grid-cols-1 gap-3.5 p-3.5 sm:grid-cols-2 lg:grid-cols-3">
        {albums.map((album) => (
          <a
            href={`/albums/${album.slug.current}`}
            class="group relative block overflow-hidden rounded-md bg-neutral-900"
          >
            <div
              class="aspect-[3/2] overflow-hidden bg-neutral-800 bg-cover bg-center"
              style={album.coverImage ? `background-image:url(${imgUrl(album.coverImage, 32)})` : undefined}
            >
              {album.coverImage && (
                <img
                  src={imgUrl(album.coverImage, 800)}
                  srcset={`${imgUrl(album.coverImage, 400)} 400w, ${imgUrl(album.coverImage, 800)} 800w, ${imgUrl(album.coverImage, 1200)} 1200w`}
                  sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
                  alt={album.title}
                  loading="lazy"
                  decoding="async"
                  data-fade
                  class="h-full w-full object-cover contrast-[1.05] saturate-[.92] transition duration-500 motion-safe:group-hover:scale-[1.03]"
                />
              )}
            </div>
            <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/80 to-transparent p-5 pt-12">
              <h2 class="text-base font-medium text-white">{album.title}</h2>
              <p class="mt-0.5 text-xs tracking-wide text-neutral-400">
                {album.photoCount} {album.photoCount === 1 ? 'photo' : 'photos'}
              </p>
            </div>
          </a>
        ))}
      </div>
    )}
  </main>
</Layout>
