---
import Layout from '../layouts/Layout.astro';
import { sanityClient } from '../lib/sanityClient';

const R2_CDN = 'https://assets.sychen6192.org';

interface Post {
  _id: string;
  title: string;
  slug: { current: string };
  coverImage: string;
  camera?: string;
  lens?: string;
  exif?: string;
}

const posts: Post[] = await sanityClient.fetch(`
  *[_type == "post"] | order(_createdAt desc) {
    _id,
    title,
    slug,
    coverImage,
    camera,
    lens,
    exif
  }
`);

function imgUrl(filename: string, width: number, quality = 85) {
  return `${R2_CDN}/cdn-cgi/image/width=${width},quality=${quality},format=auto/${filename}`;
}
---

<Layout>
  <main>
    <header>
      <span class="site-name">cloud.filmz</span>
      <span class="camera-tag">Fujifilm X-T50</span>
    </header>

    {posts.length === 0 ? (
      <div class="empty">
        <p>No posts yet. Add your first post in <a href="/admin">/admin</a>.</p>
      </div>
    ) : (
      <div class="grid">
        {posts.map((post) => (
          <article class="card">
            <div class="img-wrap">
              <img
                src={imgUrl(post.coverImage, 800)}
                srcset={`${imgUrl(post.coverImage, 400)} 400w, ${imgUrl(post.coverImage, 800)} 800w, ${imgUrl(post.coverImage, 1200)} 1200w`}
                sizes="(max-width: 600px) 100vw, (max-width: 1024px) 50vw, 33vw"
                alt={post.title}
                loading="lazy"
                decoding="async"
              />
            </div>
            <div class="meta">
              <h2 class="title">{post.title}</h2>
              {post.exif && <p class="exif">{post.exif}</p>}
              {post.lens && <p class="lens">{post.lens}</p>}
            </div>
          </article>
        ))}
      </div>
    )}
  </main>
</Layout>

<style>
  main {
    min-height: 100dvh;
    padding: 0 0 80px;
  }

  header {
    display: flex;
    align-items: baseline;
    gap: 16px;
    padding: 32px 24px 28px;
    border-bottom: 1px solid #1e1e1e;
    margin-bottom: 32px;
  }

  .site-name {
    font-size: 1.1rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: #fff;
  }

  .camera-tag {
    font-size: 0.75rem;
    font-weight: 300;
    color: #555;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 2px;
    padding: 0 2px;
  }

  @media (max-width: 480px) {
    .grid {
      grid-template-columns: 1fr;
      gap: 1px;
      padding: 0;
    }
  }

  .card {
    position: relative;
    overflow: hidden;
    background: #111;
    cursor: pointer;
  }

  .img-wrap {
    aspect-ratio: 3 / 2;
    overflow: hidden;
  }

  .img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease, filter 0.4s ease;
    filter: brightness(0.92);
  }

  .card:hover .img-wrap img {
    transform: scale(1.03);
    filter: brightness(1);
  }

  .meta {
    padding: 14px 16px 16px;
    background: linear-gradient(to bottom, #0f0f0f, #0a0a0a);
  }

  .title {
    font-size: 0.9rem;
    font-weight: 400;
    color: #ddd;
    margin-bottom: 4px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .exif {
    font-size: 0.72rem;
    color: #555;
    letter-spacing: 0.03em;
    margin-bottom: 2px;
  }

  .lens {
    font-size: 0.7rem;
    color: #3a3a3a;
    letter-spacing: 0.02em;
  }

  .empty {
    display: flex;
    justify-content: center;
    align-items: center;
    height: 60vh;
    color: #444;
    font-size: 0.9rem;
  }

  .empty a {
    color: #666;
    border-bottom: 1px solid #333;
  }
</style>
