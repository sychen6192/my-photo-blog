---
import { sanityClient } from 'sanity:client';
import Layout from '../layouts/Layout.astro';
import { imgUrl } from '../lib/image';

interface Album {
  _id: string;
  title: string;
  slug: { current: string };
  coverImage: string;
  postCount: number;
}

const albums: Album[] = await sanityClient.fetch(`
  *[_type == "album"] | order(_createdAt desc) {
    _id,
    title,
    slug,
    coverImage,
    "postCount": count(*[_type == "post" && references(^._id)])
  }
`);
---

<Layout>
  <main class="min-h-dvh pb-20">
    <header class="flex items-baseline gap-4 border-b border-neutral-800 px-6 py-8 mb-8">
      <span class="text-lg font-medium tracking-wide text-white">cloud.filmz</span>
      <span class="text-xs font-light uppercase tracking-widest text-neutral-600">
        Travel Albums
      </span>
    </header>

    {albums.length === 0 ? (
      <div class="flex h-[60vh] items-center justify-center text-sm text-neutral-600">
        <p>
          No albums yet. Create one in
          <a href="/admin" class="border-b border-neutral-700 text-neutral-400 ml-1">/admin</a>.
        </p>
      </div>
    ) : (
      <div class="grid grid-cols-1 gap-px px-px sm:grid-cols-2 lg:grid-cols-3">
        {albums.map((album) => (
          <a
            href={`/albums/${album.slug.current}`}
            class="group relative block overflow-hidden bg-neutral-900"
          >
            <div class="aspect-[3/2] overflow-hidden">
              <img
                src={imgUrl(album.coverImage, 800)}
                srcset={`${imgUrl(album.coverImage, 400)} 400w, ${imgUrl(album.coverImage, 800)} 800w, ${imgUrl(album.coverImage, 1200)} 1200w`}
                sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
                alt={album.title}
                loading="lazy"
                decoding="async"
                class="h-full w-full object-cover brightness-90 transition duration-500 group-hover:scale-[1.03] group-hover:brightness-100"
              />
            </div>
            <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/80 to-transparent p-5 pt-12">
              <h2 class="text-base font-medium text-white">{album.title}</h2>
              <p class="mt-0.5 text-xs tracking-wide text-neutral-400">
                {album.postCount} {album.postCount === 1 ? 'photo' : 'photos'}
              </p>
            </div>
          </a>
        ))}
      </div>
    )}
  </main>
</Layout>
